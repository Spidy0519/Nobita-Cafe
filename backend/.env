DJANGO_ENV=prod
DEBUG=False
SECRET_KEY=<strong-random-secret>
ALLOWED_HOSTS=<your-backend-domain>
CORS_ALLOWED_ORIGINS=<your-frontend-domain>
DATABASE_URL=<from-render-postgres>
REDIS_URL=<from-render-redis>
CLOUDINARY_URL=<if using cloudinary uploads>
MSG91_AUTH_KEY=<if using otp>
MSG91_SENDER_ID=<if using otp>
MSG91_TEMPLATE_ID=<if using otp>
RAZORPAY_KEY_ID=<if using payments>
RAZORPAY_KEY_SECRET=<if using payments>

GOOGLE_SHEET_ID=your_sheet_id_here

GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"xxx","private_key_id":"xxx","private_key":"-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n","client_email":"xxx@xxx.iam.gserviceaccount.com"}

