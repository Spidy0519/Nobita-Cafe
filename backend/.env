# ── Django Backend ──
SECRET_KEY=django-insecure-nobita-cafe-dev-key-change-in-prod
DEBUG=True
DJANGO_ENV=dev

# Database
DB_NAME=nobita_cafe
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

GOOGLE_SHEET_ID=your_sheet_id_here

GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"xxx","private_key_id":"xxx","private_key":"-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n","client_email":"xxx@xxx.iam.gserviceaccount.com"}

# MSG91 (leave blank for dev — OTP logged to console)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=NOBITA
MSG91_TEMPLATE_ID=

# Razorpay (test keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary
CLOUDINARY_URL=

# JWT
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
